# Default Docker Compose settings for the TypeScript nmap scanner.
# Copy this file to .env and adjust values for your environment.

# Browser port for the default UI container.
NMAP_UI_PORT=3000

# Browser port for the optional SYN-capable UI profile.
NMAP_UI_PORT_SYN=3001

NMAP_TARGET=host.docker.internal
NMAP_PORTS=80,443
NMAP_TOP_PORTS=20
NMAP_SCAN_TYPE=connect
NMAP_TIMING=T3
